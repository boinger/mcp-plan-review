    "start": "node build/index.js",
    "pretest": "tsc",
    "test": "node --test 'build/test/**/*.test.js'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "esmock": "^2.7.3",
    "typescript": "^5.7.3"
  }
}
