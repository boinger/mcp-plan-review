{
  "name": "mcp-plan-review",
  "version": "1.0.0",
  "description": "MCP server that sends implementation plans to a separate Claude instance for architectural review",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
